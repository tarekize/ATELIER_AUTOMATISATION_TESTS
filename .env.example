# .env.example
# Copier ce fichier en .env et remplir avec vos valeurs

# Clé API IPStack (obtenir sur https://ipstack.com)
IPSTACK_API_KEY=your_api_key_here

# Base URL API (normalement ne pas changer)
IPSTACK_BASE_URL=https://api.ipstack.com/api

# Configuration Flask (local development)
FLASK_DEBUG=True
FLASK_ENV=development

# Configuration PythonAnywhere (une fois déployé)
# DATABASE_PATH=/home/izerrouken/myapp/test_results.db
